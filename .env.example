# Admin panel password — set a strong secret, never commit the real value
ADMIN_PASSWORD=change-me-before-deploying

# Path to SQLite database file (created automatically on first run)
DATABASE_URL=./data/news.db

# Public site URL (used for OG tags, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://news.ernestofgaia.xyz

# Optional: X (Twitter) handle for "Discuss on X" links
NEXT_PUBLIC_X_HANDLE=@ErnestOfGaia

# Canonical bearer token for the publishing-agent intake endpoint (POST /api/publishing-agent/draft).
# Generate a strong random value for production (e.g. openssl rand -hex 32).
PUBLISHING_AGENT_API_KEY=change-me-to-a-strong-random-secret

# Deprecated fallback key — accepted by /api/publishing-agent/draft for backwards compat
# but /api/hermes/draft now returns 410 Gone. Set only if you have existing callers
# still using the old key. New deployments should set PUBLISHING_AGENT_API_KEY only.
HERMES_API_KEY=change-me-to-a-strong-random-secret
